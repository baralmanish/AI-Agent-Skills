{
  "purpose": "ATS (Applicant Tracking System) keyword reference by role family and industry. Use to audit resumes against job descriptions and surface missing keywords.",
  "ats_rules": {
    "why_keywords_matter": "70-80% of resumes are screened by ATS before a human sees them. Missing role-critical keywords = automatic rejection, regardless of qualifications.",
    "keyword_types": {
      "hard_skills": "Specific technologies, tools, certifications, methodologies — highest ATS weight",
      "soft_skills": "Leadership, communication, collaboration — lower ATS weight but important for human review",
      "job_title_variations": "Include common variations of your target title — ATS matches exact strings",
      "industry_terms": "Domain-specific jargon that signals familiarity with the field"
    },
    "placement_priority": [
      "Professional Summary (read by both ATS and humans)",
      "Skills section (ATS scans this section heavily)",
      "Job title and first bullet of each role",
      "Throughout experience bullets (natural integration, not keyword stuffing)"
    ],
    "keyword_density_warning": "Never force keywords unnaturally. ATS detects keyword stuffing and human reviewers reject it. Integrate keywords into real achievement statements."
  },
