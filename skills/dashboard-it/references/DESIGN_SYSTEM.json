{
  "purpose": "Design system reference for the dashboard-it skill. Governs color palettes, typography, layout patterns, and component styles used in every generated HTML dashboard.",
  "usage": "The AI picks a palette and component set from this reference based on the dashboard topic. Technical dashboards use System palette; personal/wellness dashboards use Warm; executive reports use Executive.",

  "palettes": {
    "system": {
      "use_for": "Tech, developer tools, analytics, product metrics, operational data",
      "background": "#0f172a",
      "surface": "#1e293b",
